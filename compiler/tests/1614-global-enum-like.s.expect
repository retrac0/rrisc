; rcc-generated assembly
    .org 0o1000
_start:
    li r6, 0o100
    li r1, main
    jalr r5, r1
    halt


main:
    addi r6, -1
    swr r5, r6
    addi r6, -5
;; return A+B+C
    li r1, A
    lwr r2, r1
    and r1, r6, r7
    swr r2, r1
    li r1, B
    lwr r2, r1
    and r1, r6, r7
    addi r1, 1
    swr r2, r1
    and r1, r6, r7
    lwr r3, r1
    and r1, r6, r7
    addi r1, 1
    lwr r2, r1
    clrt
    addc r2, r3, r2
    and r1, r6, r7
    addi r1, 2
    swr r2, r1
    li r1, C
    lwr r2, r1
    and r1, r6, r7
    addi r1, 3
    swr r2, r1
    and r1, r6, r7
    addi r1, 2
    lwr r3, r1
    and r1, r6, r7
    addi r1, 3
    lwr r2, r1
    clrt
    addc r2, r3, r2
    and r1, r6, r7
    addi r1, 4
    swr r2, r1
    and r1, r6, r7
    addi r1, 4
    lwr r2, r1
    li r1, _epi_main
    jalr r0, r1
_epi_main:
    addi r6, 5
    lwr r5, r6
    addi r6, 1
    jalr r0, r5

A:
    .word 0
B:
    .word 1
C:
    .word 2
