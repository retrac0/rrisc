; rcc-generated assembly
%define RCC_CODE_BASE 0o1000
%define RCC_DATA_BASE 0o0
%define RCC_STACK_TOP 0o7770
%include "crt0.s"


noop:
    subi r6, 1
    swr r5, r6
    li r1, _epi_noop
    jalr r0, r1
_epi_noop:
    lwr r5, r6
    addi r6, 1
    jalr r0, r5

main:
    subi r6, 1
    swr r5, r6
;; noop()
    li r1, noop
    jalr r5, r1
;; return 42
    li r2, 42
    li r1, _epi_main
    jalr r0, r1
_epi_main:
    lwr r5, r6
    addi r6, 1
    jalr r0, r5
