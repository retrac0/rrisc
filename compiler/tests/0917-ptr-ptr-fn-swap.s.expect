; rcc-generated assembly
%define RCC_CODE_BASE 0o1000
%define RCC_DATA_BASE 0o0
%define RCC_STACK_TOP 0o100
%include "crt0.s"


swap:
    subi r6, 1
    swr r5, r6
    subi r6, 5
    and r1, r6, r7
    swr r2, r1
    and r1, r6, r7
    addi r1, 1
    swr r3, r1
;; int t = ...
    and r1, r6, r7
    lwr r1, r1
    lwr r2, r1
    and r1, r6, r7
    addi r1, 2
    swr r2, r1
    and r1, r6, r7
    addi r1, 2
    lwr r2, r1
    and r1, r6, r7
    addi r1, 3
    swr r2, r1
;; *a=*b
    and r1, r6, r7
    addi r1, 1
    lwr r1, r1
    lwr r2, r1
    and r1, r6, r7
    addi r1, 4
    swr r2, r1
    and r1, r6, r7
    addi r1, 4
    lwr r2, r1
    and r1, r6, r7
    lwr r1, r1
    swr r2, r1
;; *b=t
    and r1, r6, r7
    addi r1, 3
    lwr r2, r1
    and r1, r6, r7
    addi r1, 1
    lwr r1, r1
    swr r2, r1
    li r1, _epi_swap
    jalr r0, r1
_epi_swap:
    addi r6, 5
    lwr r5, r6
    addi r6, 1
    jalr r0, r5

main:
    subi r6, 1
    swr r5, r6
    subi r6, 5
;; int x = ...
    li r2, 3
    and r1, r6, r7
    swr r2, r1
;; int y = ...
    li r2, 7
    and r1, r6, r7
    addi r1, 1
    swr r2, r1
;; swap(&x,&y)
    and r1, r6, r7
    and r2, r1, r7
    and r1, r6, r7
    addi r1, 2
    swr r2, r1
    and r1, r6, r7
    addi r1, 1
    and r2, r1, r7
    and r1, r6, r7
    addi r1, 3
    swr r2, r1
    and r1, r6, r7
    addi r1, 2
    lwr r2, r1
    and r1, r6, r7
    addi r1, 3
    lwr r3, r1
    li r1, swap
    jalr r5, r1
    and r1, r6, r7
    addi r1, 4
    swr r2, r1
;; return y
    li r2, 7
    li r1, _epi_main
    jalr r0, r1
_epi_main:
    addi r6, 5
    lwr r5, r6
    addi r6, 1
    jalr r0, r5
