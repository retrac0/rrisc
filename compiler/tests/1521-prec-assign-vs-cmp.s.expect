; rcc-generated assembly
    .org 0o1000
_start:
    li r6, 0o100
    li r1, main
    jalr r5, r1
    halt


main:
    subi r6, 1
    swr r5, r6
    subi r6, 2
;; int x
;; x=1==1
    li r2, 1
    and r1, r6, r7
    swr r2, r1
    li r2, 1
    and r1, r6, r7
    addi r1, 1
    swr r2, r1
;; return x
    li r2, 1
    li r1, _epi_main
    jalr r0, r1
_epi_main:
    addi r6, 2
    lwr r5, r6
    addi r6, 1
    jalr r0, r5
