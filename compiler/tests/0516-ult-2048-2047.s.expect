; rcc-generated assembly
    .org 0o1000
_start:
    li r6, 0o100
    li r1, main
    jalr r5, r1
    halt


main:
    addi r6, -1
    swr r5, r6
    addi r6, -3
;; unsigned a = ...
    lui r2, 32
    and r1, r6, r7
    swr r2, r1
;; unsigned b = ...
    li r2, 2047
    and r1, r6, r7
    addi r1, 1
    swr r2, r1
;; return a<b
    and r2, r0, r0
    and r1, r6, r7
