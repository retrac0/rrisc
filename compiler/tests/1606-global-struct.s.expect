; rcc-generated assembly
    .org 0o1000
_start:
    li r6, 0o100
    li r1, main
    jalr r5, r1
    halt


main:
    addi r6, -1
    swr r5, r6
    addi r6, -4
;; return p.x+p.y
    li r1, p
    lwr r2, r1
    and r1, r6, r7
    swr r2, r1
    li r3, p
    li r2, 1
    clrt
    addc r2, r3, r2
    and r1, r6, r7
    addi r1, 1
    swr r2, r1
    and r1, r6, r7
    addi r1, 1
    lwr r1, r1
    lwr r2, r1
    and r1, r6, r7
    addi r1, 2
    swr r2, r1
    and r1, r6, r7
    lwr r3, r1
    and r1, r6, r7
    addi r1, 2
    lwr r2, r1
    clrt
    addc r2, r3, r2
    and r1, r6, r7
    addi r1, 3
    swr r2, r1
    and r1, r6, r7
    addi r1, 3
    lwr r2, r1
    li r1, _epi_main
    jalr r0, r1
_epi_main:
    addi r6, 4
    lwr r5, r6
    addi r6, 1
    jalr r0, r5

    .org 0o0
p:
    .word 3, 4
