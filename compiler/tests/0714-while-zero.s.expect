; rcc-generated assembly
    .org 0o1000
_start:
    li r6, 0o100
    li r1, main
    jalr r5, r1
    halt


main:
    addi r6, -1
    swr r5, r6
    addi r6, -1
;; int i = ...
    and r2, r0, r0
    and r1, r6, r7
    swr r2, r1
;; while (0)
_L_while_0:
    li r1, _L_endwhile_1
    jalr r0, r1
;; i=99
    li r2, 99
    and r1, r6, r7
    swr r2, r1
    li r1, _L_while_0
    jalr r0, r1
_L_endwhile_1:
;; return i
    and r1, r6, r7
    lwr r2, r1
    li r1, _epi_main
    jalr r0, r1
_epi_main:
    addi r6, 1
    lwr r5, r6
    addi r6, 1
    jalr r0, r5
